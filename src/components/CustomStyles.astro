---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  /*
    Fintech Lawyer brand schema
    Source of truth: /tailwindtoolbox-landing-page

    --fl-* tokens are the named brand palette.
    --aw-* tokens adapt that palette to Astrowind templates and components.
  */
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --fl-brand-navy: #1d4771;
    --fl-brand-blue: #0365b2;
    --fl-brand-navy-dark: #0d3d7c;
    --fl-ink: #2e2e2e;
    --fl-text-secondary: #57534e;
    --fl-text-muted: #78716c;
    --fl-border-subtle: #d1d5db;
    --fl-surface: #ffffff;
    --fl-surface-soft: #fafaf9;
    --fl-gradient-brand: linear-gradient(90deg, var(--fl-brand-navy) 0%, var(--fl-brand-blue) 100%);

    --aw-color-primary: 29 71 113;
    --aw-color-secondary: 3 101 178;
    --aw-color-accent: 13 61 124;

    --aw-color-text-heading: 46 46 46;
    --aw-color-text-default: 46 46 46;
    --aw-color-text-muted: 87 83 78;
    --aw-color-text-subtle: 120 113 108;
    --aw-color-border-subtle: 209 213 219;
    --aw-color-bg-page: 255 255 255;
    --aw-color-bg-soft: 250 250 249;

    --aw-color-bg-page-dark: 13 61 124;

    ::selection {
      background-color: #ddeaf6;
      color: var(--fl-ink);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --fl-brand-navy: #1d4771;
    --fl-brand-blue: #0365b2;
    --fl-brand-navy-dark: #0d3d7c;
    --fl-ink: #2e2e2e;
    --fl-text-secondary: #57534e;
    --fl-text-muted: #78716c;
    --fl-border-subtle: #d1d5db;
    --fl-surface: #ffffff;
    --fl-surface-soft: #fafaf9;
    --fl-gradient-brand: linear-gradient(90deg, var(--fl-brand-navy) 0%, var(--fl-brand-blue) 100%);

    --aw-color-primary: 29 71 113;
    --aw-color-secondary: 3 101 178;
    --aw-color-accent: 13 61 124;

    --aw-color-text-heading: 247 248 248;
    --aw-color-text-default: 229 236 246;
    --aw-color-text-muted: 209 213 219;
    --aw-color-text-subtle: 209 213 219;
    --aw-color-border-subtle: 209 213 219;
    --aw-color-bg-page: 13 61 124;
    --aw-color-bg-soft: 29 71 113;

    ::selection {
      background-color: #ddeaf6;
      color: #2e2e2e;
    }
  }
</style>
