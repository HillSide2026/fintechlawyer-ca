---
import type { ImageMetadata } from 'astro';
import PostTags from '~/components/blog/Tags.astro';
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
---

<article class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
  <div class="mb-2 flex items-center gap-3 text-sm text-muted">
    {post.publishDate && (
      <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
    )}
    {post.category && (
      <>
        <span>·</span>
        <a class="hover:underline hover:text-primary" href={getPermalink(post.category.slug, 'category')}>
          {post.category.title}
        </a>
      </>
    )}
  </div>

  <h2 class="font-heading text-2xl font-bold leading-tight tracking-tight text-heading md:text-3xl">
    {link ? (
      <a class="hover:text-primary transition ease-in duration-200" href={link}>
        {post.title}
      </a>
    ) : (
      post.title
    )}
  </h2>

  {post.excerpt && (
    <p class="mt-3 text-lg text-muted">{post.excerpt}</p>
  )}

  {post.tags && Array.isArray(post.tags) && post.tags.length > 0 && (
    <div class="mt-4">
      <PostTags tags={post.tags} />
    </div>
  )}
</article>
