---
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';
import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post } = Astro.props;
---

<section class="mx-auto max-w-7xl px-4 md:px-6 py-14 md:py-20">
  <div class="max-w-3xl">
    {post.category && (
      <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">
        <a href={getPermalink(post.category.slug, 'category')} class="hover:underline">
          {post.category.title}
        </a>
      </p>
    )}

    <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight text-heading md:text-5xl">
      {post.title}
    </h1>

    {post.excerpt && (
      <p class="mt-6 text-xl text-muted md:text-2xl">{post.excerpt}</p>
    )}

    <p class="mt-4 text-sm text-muted">
      {post.publishDate && <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>}
      {post.author && <span> · {post.author}</span>}
    </p>

    <div class="mt-2 border-t border-gray-200 dark:border-slate-700" />
  </div>

  <div class="mt-10 max-w-3xl prose prose-lg dark:prose-invert prose-headings:font-heading prose-headings:font-bold prose-headings:tracking-tight prose-a:text-primary dark:prose-a:text-blue-400 prose-headings:scroll-mt-[80px]">
    <slot />
  </div>

  {post.tags && post.tags.length > 0 && (
    <div class="mt-10 max-w-3xl pt-6 border-t border-gray-200 dark:border-slate-700 flex flex-wrap gap-2">
      {post.tags.map((tag) => (
        <a
          href={getPermalink(tag.slug, 'tag')}
          class="text-xs font-medium px-3 py-1 border border-gray-200 dark:border-slate-700 text-muted hover:border-primary hover:text-primary transition"
        >
          {tag.title}
        </a>
      ))}
    </div>
  )}
</section>
