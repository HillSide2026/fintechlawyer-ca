---
import { headerData } from '~/navigation';
---

<nav class="fixed w-full z-30 top-0 text-white bg-brand-gradient shadow">
  <div class="w-full container mx-auto flex flex-wrap items-center justify-between mt-0 py-2">
    <div class="pl-4 flex items-center">
      <a class="text-white no-underline hover:no-underline font-bold text-2xl lg:text-4xl" href="/">
        <svg class="h-8 fill-current inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512.005 512.005">
          <rect fill="#FFFFFF" x="16.539" y="425.626" width="479.767" height="50.502" />
          <path d="M 510.7 189.151 C 505.271 168.95 484.565 156.956 464.365 162.385 L 330.156 198.367 L 155.924 35.878 L 107.19 49.008 L 211.729 230.183 L 86.232 263.767 L 36.614 224.754 L 0 234.603 L 45.957 314.27 L 65.274 347.727 L 105.802 336.869 L 240.011 300.886 L 349.726 271.469 L 483.935 235.486 C 504.134 230.057 516.129 209.352 510.7 189.151 Z" />
        </svg>
        Fintech Lawyer
      </a>
    </div>

    <div class="block lg:hidden pr-4">
      <button
        id="site-nav-toggle"
        class="flex items-center p-1 text-white hover:text-[#DDEAF6] focus:outline-none focus:shadow-outline transform transition hover:scale-105 duration-300 ease-in-out"
        type="button"
        aria-label="Toggle navigation"
      >
        <svg class="fill-current h-6 w-6" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          <title>Menu</title>
          <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z" />
        </svg>
      </button>
    </div>

    <div
      id="site-nav-content"
      class="w-full flex-grow lg:flex lg:items-center lg:w-auto hidden mt-2 lg:mt-0 bg-transparent text-white p-4 lg:p-0 z-20"
    >
      <ul class="list-reset lg:flex justify-end flex-1 items-center">
        {headerData.links.map((link) => (
          <li class="mr-3">
            <a
              class="inline-block py-2 px-4 text-white no-underline hover:text-[#DDEAF6] font-medium"
              href={link.href}
            >
              {link.text}
            </a>
          </li>
        ))}
      </ul>
      <a
        href="/login"
        class="mx-auto lg:mx-0 hover:underline bg-white text-[#2E2E2E] font-bold rounded-full mt-4 lg:mt-0 py-4 px-8 shadow opacity-90 focus:outline-none focus:shadow-outline transform transition hover:scale-105 duration-300 ease-in-out"
      >
        Portal
      </a>
    </div>
  </div>
  <hr class="border-b border-[#D1D5DB] opacity-25 my-0 py-0" />
</nav>

<script>
  const toggle = document.getElementById('site-nav-toggle');
  const content = document.getElementById('site-nav-content');
  toggle?.addEventListener('click', () => content?.classList.toggle('hidden'));
</script>
