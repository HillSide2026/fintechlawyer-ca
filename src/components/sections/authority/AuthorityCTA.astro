---
import Button from '~/components/ui/Button.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { commonAuthorityCTA } from '~/data/authorityPages';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  title?: string;
  text?: string;
}

const { title = commonAuthorityCTA.title, text = commonAuthorityCTA.text } = Astro.props;
---

<WidgetWrapper containerClass="py-12 md:py-16 text-center">
  <div class="mx-auto max-w-3xl">
    <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Keep reading</p>
    <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">{title}</h2>
    <p class="mt-4 text-lg text-muted">{text}</p>
    <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
      <Button variant="primary" href={getPermalink('/insights')} text="Explore insights" />
      <Button variant="secondary" href={getPermalink('/fintrac-compliance')} text="FINTRAC/MSB hub" />
    </div>
  </div>
</WidgetWrapper>
