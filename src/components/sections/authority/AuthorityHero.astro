---
import type { AuthorityPage } from '~/data/authorityPages';

export interface Props {
  page: AuthorityPage;
}

const { page } = Astro.props;
---

<section class="relative not-prose">
  <div class="mx-auto max-w-7xl px-4 md:px-6 py-14 md:py-20 lg:py-24">
    <div class="max-w-4xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">{page.eyebrow}</p>
      <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight text-heading md:text-5xl">
        {page.title}
      </h1>
      <p class="mt-6 max-w-3xl text-lg text-muted md:text-xl">{page.description}</p>
    </div>
  </div>
</section>
