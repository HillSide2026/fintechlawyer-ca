---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { AuthorityLink } from '~/data/authorityPages';

export interface Props {
  links: AuthorityLink[];
}

const { links } = Astro.props;
---

<WidgetWrapper containerClass="pt-0">
  <div class="mb-8 max-w-3xl">
    <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Insights</p>
    <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
      Practical analysis supporting this topic.
    </h2>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    {
      links.map((link) => (
        <a class="block border border-gray-200 p-5 transition hover:border-primary dark:border-slate-700" href={link.href}>
          <h3 class="text-lg font-semibold text-heading">{link.title}</h3>
          <p class="mt-2 text-muted">{link.description}</p>
        </a>
      ))
    }
  </div>
</WidgetWrapper>
