---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { AuthorityLink } from '~/data/authorityPages';

export interface Props {
  links: AuthorityLink[];
}

const { links } = Astro.props;
---

<WidgetWrapper containerClass="pt-0">
  <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Related topics</p>
      <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
        Connected legal and regulatory context.
      </h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {
        links.map((link) => (
          <a class="border border-gray-200 p-4 transition hover:border-primary dark:border-slate-700" href={link.href}>
            <h3 class="font-semibold text-heading">{link.title}</h3>
            <p class="mt-1 text-sm text-muted">{link.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</WidgetWrapper>
