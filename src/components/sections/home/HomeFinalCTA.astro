---
import Button from '~/components/ui/Button.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { getPermalink } from '~/utils/permalinks';
---

<WidgetWrapper id="contact" containerClass="py-14 md:py-20 text-center">
  <div class="mx-auto max-w-3xl">
    <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Start a conversation</p>
    <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
      Bring legal clarity to the next fintech decision.
    </h2>
    <p class="mt-4 text-lg text-muted">
      Share what you are building, where you are blocked, and what decisions are coming next.
    </p>
    <div class="mt-8">
      <Button variant="primary" href={getPermalink('/contact')} text="Contact fintechlawyer.ca" />
    </div>
  </div>
</WidgetWrapper>
