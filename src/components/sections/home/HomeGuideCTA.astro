---
import Button from '~/components/ui/Button.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { getPermalink } from '~/utils/permalinks';
---

<WidgetWrapper id="guide" containerClass="py-10 md:py-14">
  <div class="border border-gray-200 p-6 md:p-8 dark:border-slate-700">
    <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Guide</p>
        <h2 class="font-heading text-2xl font-bold leading-tight tracking-tight text-heading md:text-3xl">
          Get Oriented Before The Next Fintech Decision.
        </h2>
        <p class="mt-3 text-muted">
          A guide can help teams frame the questions to ask before a product launch, partnership, financing, or
          regulatory review.
        </p>
      </div>
      <Button variant="primary" href={getPermalink('/fintrac-compliance')} text="Read the guide" />
    </div>
  </div>
</WidgetWrapper>
