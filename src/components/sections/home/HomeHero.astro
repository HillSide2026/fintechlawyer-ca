---
import Button from '~/components/ui/Button.astro';
import { getPermalink } from '~/utils/permalinks';
---

<section class="relative not-prose">
  <div class="mx-auto max-w-7xl px-4 md:px-6 py-16 md:py-24 lg:py-28">
    <div class="max-w-4xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">
        Leading source for fintech legal and regulatory info
      </p>
      <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight text-heading md:text-5xl lg:text-6xl">
        Legal strategy for fintech companies building in Canada.
      </h1>
      <p class="mt-6 max-w-3xl text-lg text-muted md:text-xl">
        fintechlawyer.ca helps founders, operators, and financial services teams navigate product launches,
        regulatory questions, partnerships, and growth with practical legal and regulatory information.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button variant="primary" href={getPermalink('/contact')} text="Request Consultation" />
        <Button variant="secondary" href={getPermalink('/insights')} text="Explore Knowledge" />
      </div>
    </div>
  </div>
</section>
