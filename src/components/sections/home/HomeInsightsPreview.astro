---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { insightLinks } from '~/data/authorityPages';
import { getBlogPermalink } from '~/utils/permalinks';

const insights = insightLinks;
---

<WidgetWrapper id="insights">
  <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div class="max-w-3xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Insights</p>
      <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
        Practical writing for fintech teams.
      </h2>
    </div>
    <a class="font-semibold text-primary hover:underline" href={getBlogPermalink()}>Read insights</a>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    {
      insights.map((insight) => (
        <article class="border border-gray-200 p-5 dark:border-slate-700">
          <h3 class="text-lg font-semibold text-heading">{insight.title}</h3>
          <p class="mt-2 text-muted">{insight.description}</p>
          <a class="mt-4 inline-block text-sm font-semibold text-primary hover:underline" href={insight.href}>
            View topic
          </a>
        </article>
      ))
    }
  </div>
</WidgetWrapper>
