---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
---

<WidgetWrapper id="system-map">
  <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">System map</p>
      <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
        Fintech Sits Inside a Connected Legal and Regulatory System.
      </h2>
      <p class="mt-4 text-lg text-muted">
        Product decisions, regulatory obligations, commercial contracts, privacy, compliance, and investor expectations
        move together. Our goal is to make that system easy to understand.
      </p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        [
          ['Product', 'Structure new financial products with regulatory risk in view.'],
          ['Regulation', 'Map licensing, registration, payments, lending, AML, and consumer protection issues.'],
          ['Contracts', 'Support banking, processor, sponsor, vendor, customer, and partnership agreements.'],
          ['Growth', 'Prepare teams for financing, diligence, scaling, and market expansion.'],
        ].map(([title, description]) => (
          <article class="border border-gray-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900">
            <h3 class="text-lg font-semibold text-heading">{title}</h3>
            <p class="mt-2 text-muted">{description}</p>
          </article>
        ))
      }
    </div>
  </div>
</WidgetWrapper>
