---
import Button from '~/components/ui/Button.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { VerticalPageData } from '~/data/verticalPages';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  page: VerticalPageData;
}

const { page } = Astro.props;
---

<section class="relative not-prose">
  <div class="mx-auto max-w-7xl px-4 md:px-6 py-14 md:py-20 lg:py-24">
    <div class="max-w-4xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">{page.eyebrow}</p>
      <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight text-heading md:text-5xl">
        {page.title}
      </h1>
      <p class="mt-6 max-w-3xl text-lg text-muted md:text-xl">{page.description}</p>
      <p class="mt-4 max-w-3xl text-lg text-muted">{page.audience}</p>
    </div>
  </div>
</section>

<WidgetWrapper containerClass="pt-0">
  <div class="max-w-3xl">
    <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
      {page.practiceTitle}
    </h2>
    <ul class="mt-6 list-disc space-y-3 pl-5 text-lg text-muted">
      {page.practicePoints.map((point) => <li>{point}</li>)}
    </ul>
  </div>
</WidgetWrapper>

<WidgetWrapper containerClass="pt-0">
  <div class="mb-10 max-w-3xl">
    <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
      {page.modelsTitle}
    </h2>
  </div>
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {
      page.models.map((model) => (
        <article class="border border-gray-200 p-5 dark:border-slate-700">
          <h3 class="text-lg font-semibold text-heading">{model.title}</h3>
          <p class="mt-2 text-muted">{model.description}</p>
        </article>
      ))
    }
  </div>
</WidgetWrapper>

<WidgetWrapper containerClass="pt-0">
  <div class="max-w-3xl">
    <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
      {page.regulationTitle}
    </h2>
    <p class="mt-4 text-lg text-muted">{page.regulationText}</p>
  </div>
</WidgetWrapper>

<WidgetWrapper containerClass="pt-0">
  <div class="mb-8 max-w-3xl">
    <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
      Related Topics
    </h2>
  </div>
  <div class="grid gap-4 md:grid-cols-2">
    {
      page.relatedTopics.map((topic) => (
        <a class="block border border-gray-200 p-5 transition hover:border-primary dark:border-slate-700" href={topic.href}>
          <h3 class="text-lg font-semibold text-heading">{topic.title}</h3>
          <p class="mt-2 text-muted">{topic.description}</p>
        </a>
      ))
    }
  </div>
</WidgetWrapper>

<WidgetWrapper containerClass="pt-0 pb-16 md:pb-20">
  <div class="border border-gray-200 p-6 md:p-8 dark:border-slate-700">
    <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <p class="text-lg text-muted">{page.ctaText}</p>
      <Button
        variant="primary"
        href={getPermalink('/contact')}
        text="Request Consultation"
        class="w-full text-center sm:w-auto"
      />
    </div>
  </div>
</WidgetWrapper>
