---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About FintechLawyer',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About FintechLawyer"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Caos Image',
    }}
  >
    <Fragment slot="title">
      Legal Infrastructure for Modern Fintech Companies
    </Fragment>

    <Fragment slot="subtitle">
      FintechLawyer helps founders and operators navigate regulatory complexity with clarity and confidence. From early-stage structuring to scaling across jurisdictions, we provide practical, business-first legal guidance built for fast-moving teams.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Trusted by High-Growth Teams"
    stats={[
      { title: 'Clients Advised', amount: '200+' },
      { title: 'Jurisdictions Covered', amount: '15+' },
      { title: 'Transactions Supported', amount: '$500M+' },
      { title: 'Years in Practice', amount: '10+' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="What We Do"
    subtitle="Specialized legal services designed for fintech innovators, operators and digital financial products."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Regulatory Strategy',
        description:
          'Navigate licensing, compliance, and regulatory risk across multiple jurisdictions with clear, actionable guidance.',
        icon: 'tabler:scale',
      },
      {
        title: 'Fintech Structuring',
        description:
          'Build the right legal foundation for payments, lending, crypto, and embedded finance products.',
        icon: 'tabler:building-bank',
      },
      {
        title: 'Securities & Fundraising',
        description:
          'Support for SAFE, equity rounds, token offerings, and investor documentation.',
        icon: 'tabler:chart-line',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Payments & Money Services',
        description:
          'Advising on MSB registration, payment flows, and partnerships with financial institutions.',
        icon: 'tabler:credit-card',
      },
      {
        title: 'Crypto & Web3',
        description:
          'Guidance on token design, compliance frameworks, and evolving regulatory expectations.',
        icon: 'tabler:currency-bitcoin',
      },
      {
        title: 'Commercial Contracts',
        description:
          'Drafting and negotiating agreements with partners, vendors, and financial institutions.',
        icon: 'tabler:file-text',
      },
      {
        title: 'Privacy & Data Protection',
        description:
          'Ensure compliance with GDPR, PIPEDA, and global data frameworks.',
        icon: 'tabler:lock',
      },
      {
        title: 'Ongoing Legal Support',
        description:
          'Acting as fractional counsel for growing fintech companies.',
        icon: 'tabler:briefcase',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Colorful Image',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="How We Work"
    subtitle="We combine legal precision with digital speed, delivering advice that is both rigorous and practical."
    items={[
      {
        title: 'Business-First Thinking',
        description:
          'Legal advice grounded in real operational and growth needs.',
      },
      {
        title: 'Clarity Over Complexity',
        description:
          'We simplify complex regulations into clear decisions and next steps.',
      },
      {
        title: 'Speed & Responsiveness',
        description:
          'Fast-moving teams need fast-moving legal support. We keep pace.',
      },
      {
        title: 'Integrity & Compliance',
        description:
          'We prioritize long-term sustainability, not shortcuts that create future risk.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Proven Experience"
    subtitle="A track record of supporting fintech companies from launch to scale."
    isReversed={true}
    callToAction={{
      text: 'View Case Studies',
      href: '/',
    }}
    items={[
      {
        title: 'Global Client Base',
        description: 'Advising startups and platforms operating across North America, Europe, and beyond.',
        icon: 'tabler:globe',
      },
      {
        title: 'Strong Founder Relationships',
        description:
          'Long-term partnerships with repeat clients and referrals.',
        icon: 'tabler:message-star',
      },
      {
        title: 'Recognized Expertise',
        description:
          'Deep specialization in fintech, payments, and emerging financial technologies.',
        icon: 'tabler:award',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Where We Operate"
    tagline="Global Reach"
    columns={4}
    items={[
      {
        title: 'Ontario (HQ)',
        description: 'Toronto',
      },
      {
        title: 'British Columbia',
        description: 'Vancouver',
      },
      {
        title: 'LatAm',
        description: 'Brazil',
      },
      {
        title: 'Europe',
        description: 'London',
      },
      {
        title: 'APAC',
        description: 'Tokyo',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Speak with a Fintech Lawyer"
    tagline="Contact"
    columns={2}
    items={[
      {
        title: 'Schedule a Consultation',
        description:
          'Book time to discuss your product, structure, or regulatory questions.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Email Us',
        description:
          'Reach out for general inquiries or partnership opportunities.',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
