---
import Button from '~/components/ui/Button.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { fintracClusterLinks } from '~/data/authorityPages';
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Payments Law and Regulation in Canada',
  description:
    'An overview of how payments businesses operate in Canada and where legal and regulatory considerations typically arise.',
};

const practicePoints = [
  'Most fintech payment products sit between users, platforms, and financial institutions.',
  'Banks, processors, and infrastructure providers each perform distinct roles.',
  'Fintech companies focus on user experience and coordination across systems.',
  'Regulation tends to follow how money moves, rather than how the product is described.',
];

const businessModels = [
  {
    title: 'Payment Processing',
    description:
      'Enables businesses to accept and manage payments without operating as financial institutions. Typically structured through partnerships, with considerations around control and risk allocation.',
  },
  {
    title: 'Marketplaces and Platforms',
    description:
      'Platforms embed payments into user interactions. Fund flows between participants influence operational structure and regulatory exposure.',
  },
  {
    title: 'Wallets and Stored Value',
    description:
      'Users hold balances or transact within a system. These features often receive closer scrutiny from regulators and banking partners.',
  },
  {
    title: 'Money Movement and Transfers',
    description:
      'Movement of funds between users or businesses, including domestic and cross-border transfers, is central to many fintech products.',
  },
  {
    title: 'FX and Cross-Border',
    description:
      'Multi-currency and international payments introduce complexity in conversion, routing, and settlement across jurisdictions.',
  },
  {
    title: 'Embedded Payments',
    description:
      'Payments integrated into software platforms. Product design decisions influence how responsibility and risk are allocated.',
  },
];

const regulatoryConsiderations = [
  'Receipt or holding of customer funds.',
  'Movement of funds between users or businesses.',
  'Control over the timing or routing of payments.',
  'Ability for users to store value or maintain balances.',
  'Foreign exchange and cross-border transactions.',
];

const fintracPaymentLinks = [
  fintracClusterLinks[0],
  fintracClusterLinks[1],
  fintracClusterLinks[3],
  fintracClusterLinks[4],
  fintracClusterLinks[5],
];

const relatedTopics = [
  {
    title: 'FINTRAC Compliance Overview',
    description: 'Return to the FINTRAC/MSB hub for the broader compliance structure.',
    href: getPermalink('/fintrac-compliance'),
  },
  {
    title: 'Insights',
    description: 'Read practical Canadian fintech legal and regulatory analysis.',
    href: getPermalink('/insights'),
  },
];
---

<Layout metadata={metadata}>
  <section class="relative not-prose">
    <div class="mx-auto max-w-7xl px-4 md:px-6 py-14 md:py-20 lg:py-24">
      <div class="max-w-4xl">
        <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">
          Payments
        </p>
        <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight text-heading md:text-5xl">
          Payments Law and Regulation in Canada
        </h1>
        <p class="mt-6 max-w-3xl text-lg text-muted md:text-xl">
          An overview of how payments businesses operate in Canada and where legal and regulatory considerations
          typically arise.
        </p>
        <p class="mt-4 max-w-3xl text-lg text-muted">
          Designed for fintech founders, product teams, and operators building or scaling payment functionality.
        </p>
      </div>
    </div>
  </section>

  <WidgetWrapper containerClass="pt-0">
    <div class="max-w-3xl">
      <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
        How Payments Work in Practice
      </h2>
      <p class="mt-4 text-lg text-muted">Payments products typically operate across multiple participants and systems.</p>
      <ul class="mt-6 list-disc space-y-3 pl-5 text-lg text-muted">
        {practicePoints.map((point) => <li>{point}</li>)}
      </ul>
    </div>
  </WidgetWrapper>

  <WidgetWrapper containerClass="pt-0">
    <div class="mb-10 max-w-3xl">
      <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
        How Payments Businesses Are Built in Practice
      </h2>
    </div>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        businessModels.map((model) => (
          <article class="border border-gray-200 p-5 dark:border-slate-700">
            <h3 class="text-lg font-semibold text-heading">{model.title}</h3>
            <p class="mt-2 text-muted">{model.description}</p>
          </article>
        ))
      }
    </div>
  </WidgetWrapper>

  <WidgetWrapper containerClass="pt-0">
    <div class="max-w-3xl">
      <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
        Regulatory Considerations in Payments
      </h2>
      <p class="mt-4 text-lg text-muted">
        Certain product features and payment flows tend to engage regulatory frameworks.
      </p>
      <ul class="mt-6 list-disc space-y-3 pl-5 text-lg text-muted">
        {regulatoryConsiderations.map((point) => <li>{point}</li>)}
      </ul>
      <p class="mt-6 text-lg text-muted">
        In Canada, these activities are commonly associated with obligations under FINTRAC and the money services
        business (MSB) regime, depending on how the product is structured and how funds move through the system.
      </p>
    </div>
  </WidgetWrapper>

  <WidgetWrapper containerClass="pt-0">
    <div class="mb-10 max-w-3xl">
      <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
        FINTRAC and Payments Framework
      </h2>
      <p class="mt-4 text-lg text-muted">
        Payments businesses operating in Canada may fall within the scope of FINTRAC oversight where their activities
        involve facilitating transactions, transmitting funds, or otherwise participating in the movement of money.
      </p>
      <p class="mt-4 text-lg text-muted">
        Application of the MSB regime depends on the role the business plays within the transaction flow, including
        whether it controls funds, intermediates transfers, or provides payment functionality beyond software.
      </p>
    </div>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        fintracPaymentLinks.map((link) => (
          <a class="block border border-gray-200 p-5 transition hover:border-primary dark:border-slate-700" href={link.href}>
            <h3 class="text-lg font-semibold text-heading">{link.title}</h3>
            <p class="mt-2 text-muted">{link.description}</p>
          </a>
        ))
      }
    </div>
  </WidgetWrapper>

  <WidgetWrapper containerClass="pt-0">
    <div class="mb-8 max-w-3xl">
      <h2 class="font-heading text-3xl font-bold leading-tight tracking-tight text-heading md:text-4xl">
        Related Topics
      </h2>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {
        relatedTopics.map((topic) => (
          <a class="block border border-gray-200 p-5 transition hover:border-primary dark:border-slate-700" href={topic.href}>
            <h3 class="text-lg font-semibold text-heading">{topic.title}</h3>
            <p class="mt-2 text-muted">{topic.description}</p>
          </a>
        ))
      }
    </div>
  </WidgetWrapper>

  <WidgetWrapper containerClass="pt-0 pb-16 md:pb-20">
    <div class="border border-gray-200 p-6 md:p-8 dark:border-slate-700">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="font-heading text-2xl font-bold leading-tight tracking-tight text-heading md:text-3xl">
            Structuring Payments Products
          </h2>
          <p class="mt-3 text-muted">
            Early decisions around product design and fund flows influence regulatory scope and operational flexibility
            for payments businesses in Canada.
          </p>
        </div>
        <Button
          variant="primary"
          href={getPermalink('/contact')}
          text="Request Consultation"
          class="w-full text-center sm:w-auto"
        />
      </div>
    </div>
  </WidgetWrapper>
</Layout>
