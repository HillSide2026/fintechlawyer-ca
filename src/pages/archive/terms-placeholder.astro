---
import Layout from '~/layouts/PageLayout.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

const metadata = {
  title: 'Terms',
  description: 'Terms for Fintech Lawyer services and materials.',
};
---

<Layout metadata={metadata}>
  <WidgetWrapper>
    <section class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Legal</p>
      <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight text-heading md:text-5xl">Terms</h1>
      <p class="mt-6 text-lg leading-8 text-muted md:text-xl">
        This page will contain the terms governing the use of Fintech Lawyer services and materials.
      </p>
      <p class="mt-4 text-base leading-7 text-muted">This is placeholder content and will be replaced.</p>
    </section>
  </WidgetWrapper>
</Layout>
