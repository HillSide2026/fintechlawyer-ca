---
import PageLayout from '~/layouts/PageLayout.astro';
import List from '~/components/blog/List.astro';
import { fetchPosts } from '~/utils/blog';

const metadata = {
  title: 'Insights — Practical Canadian fintech legal and regulatory analysis',
  description: 'Practical writing on Canadian fintech law, MSB registration, FINTRAC compliance, payment structuring, and regulatory issues for fintech companies.',
};

const posts = await fetchPosts();
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 md:px-6 py-14 md:py-20">
    <div class="max-w-3xl mb-12 md:mb-16">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Insights</p>
      <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight text-heading md:text-5xl">
        Practical Canadian fintech legal and regulatory analysis.
      </h1>
      <p class="mt-6 text-xl text-muted">
        Writing on MSB registration, FINTRAC compliance, payment structuring, and legal issues relevant to fintech founders and operators.
      </p>
    </div>

    {posts.length > 0 ? (
      <List posts={posts} />
    ) : (
      <p class="text-muted">No insights published yet.</p>
    )}
  </section>
</PageLayout>
