---
import Layout from '~/layouts/PageLayout.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Contact fintechlawyer.ca',
  description: 'Contact fintechlawyer.ca about Canadian fintech legal and regulatory information.',
};
---

<Layout metadata={metadata}>
  <WidgetWrapper>
    <div class="max-w-3xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200">Contact</p>
      <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight text-heading md:text-5xl">
        Share a Canadian fintech legal or regulatory question.
      </h1>
      <p class="mt-6 text-lg text-muted md:text-xl">
        fintechlawyer.ca is being built as a practical authority source for Canadian fintech legal and regulatory
        information. For now, use this page as the contact point for consultation requests, corrections, source
        suggestions, and topic ideas.
      </p>
      <div class="mt-8 border border-gray-200 p-6 dark:border-slate-700">
        <h2 class="text-2xl font-semibold text-heading">Suggested context</h2>
        <ul class="mt-4 list-disc space-y-2 pl-5 text-muted">
          <li>The product, business model, or regulatory topic.</li>
          <li>The Canadian jurisdiction or regulator involved, if known.</li>
          <li>The decision you are trying to make next.</li>
        </ul>
      </div>
      <p class="mt-8 text-muted">
        Start with the <a class="font-semibold text-primary hover:underline" href={getPermalink('/fintrac-compliance')}>FINTRAC/MSB hub</a>
        or the <a class="font-semibold text-primary hover:underline" href={getPermalink('/insights')}>insights library</a>
        if you are researching a topic before reaching out.
      </p>
    </div>
  </WidgetWrapper>
</Layout>
