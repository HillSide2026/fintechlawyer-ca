---
import PageLayout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Matthew Levine — Canadian Fintech Lawyer',
  description: 'Matthew Levine advises fintech founders and operators on Canadian regulatory strategy, MSB registration, FINTRAC compliance, payment structuring, and commercial matters.',
};
---

<PageLayout metadata={metadata}>

  <!-- Hero -->
  <section class="relative not-prose bg-brand-gradient text-white">
    <div class="mx-auto max-w-7xl px-4 md:px-6 py-16 md:py-24 lg:py-28">
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-blue-200">Counsel</p>
        <h1 class="font-heading text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl">
          Matthew Levine
        </h1>
        <p class="mt-4 text-xl text-blue-200 font-medium">Founder, Levine Legal</p>
        <p class="mt-6 max-w-2xl text-lg text-blue-100 md:text-xl">
          Corporate and regulatory counsel for fintech founders and operators navigating the Canadian legal and regulatory environment.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={getPermalink('/contact')}
            class="inline-block bg-white px-8 py-4 text-sm font-bold text-[#1D4771] hover:bg-blue-50 transition"
          >
            Request Consultation
          </a>
          <a
            href={getPermalink('/login')}
            class="inline-block border border-white px-8 py-4 text-sm font-bold text-white hover:bg-white/10 transition"
          >
            Client Portal
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-linkedin',
        callToAction: {
          target: '_blank',
          text: 'LinkedIn',
          href: 'https://www.linkedin.com/in/matthewajlevine',
        },
      },
      {
        icon: 'tabler:brand-x',
        callToAction: {
          target: '_blank',
          text: 'X / Twitter',
          href: 'https://twitter.com/MatthewAJLevine',
        },
      },
      {
        icon: 'tabler:building',
        callToAction: {
          text: 'Levine Law',
          href: 'https://levinelegal.ca',
        },
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1560250097-0b93528c311a?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80',
      alt: 'Matthew Levine',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4">About Matthew</h2>
      <p>
        Matthew Levine is the founder of Levine Legal, a Toronto-based corporate law firm advising entrepreneurs and executives on corporate structures, transactions, and financing matters.
      </p>
      <br />
      <p>
        Matthew's practice is concentrated on the legal and regulatory issues facing Canadian fintech companies — including MSB registration, FINTRAC compliance, payment product structuring, banking relationships, and commercial contracts with financial institution partners.
      </p>
      <br />
      <p>
        fintechlawyer.ca is Matthew's public-facing resource for practical regulatory intelligence on Canadian fintech law.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Experience -->
  <Steps
    id="experience"
    title="Experience"
    items={[
      {
        title: 'Founder <br /> <span class="font-normal">Levine Legal, Toronto, ON</span> <br /> <span class="text-sm font-normal">Current</span>',
        description: 'Corporate and regulatory counsel for fintech founders and executives. Practice areas include MSB registration, FINTRAC compliance, payment structuring, securities law, and commercial contracts.',
        icon: 'tabler:briefcase',
      },
      {
        title: '[Prior Role] <br /> <span class="font-normal">[Firm], [City]</span> <br /> <span class="text-sm font-normal">[Years]</span>',
        description: '[Placeholder — add prior experience here]',
        icon: 'tabler:briefcase',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Education -->
  <Steps
    id="education"
    title="Education"
    items={[
      {
        title: '[Degree] <br /> <span class="font-normal">[Law School]</span> <br /> <span class="text-sm font-normal">[Years]</span>',
        icon: 'tabler:school',
      },
      {
        title: '[Undergraduate Degree] <br /> <span class="font-normal">[University]</span> <br /> <span class="text-sm font-normal">[Years]</span>',
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Practice areas -->
  <Features3
    title="Practice areas"
    subtitle="Legal and regulatory work concentrated on the issues facing Canadian fintech companies."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'MSB Registration',
        description: 'Advising on when registration is required, sequencing the process, and managing FINTRAC obligations from the outset.',
      },
      {
        title: 'FINTRAC Compliance',
        description: 'Building AML compliance programs, policies, and controls that satisfy FINTRAC requirements and survive examination.',
      },
      {
        title: 'Payment Structuring',
        description: 'Mapping fund flows, role allocation, and product architecture against the Canadian regulatory framework.',
      },
      {
        title: 'Banking Relationships',
        description: 'Advising on banking access strategy, onboarding preparation, and response to de-risking by financial institutions.',
      },
      {
        title: 'Crypto and Digital Assets',
        description: 'Regulatory analysis for virtual currency dealers, token structures, and digital asset products under Canadian law.',
      },
      {
        title: 'Corporate Structuring',
        description: 'Setting up the right corporate structure for fintech operations, investment, and regulatory compliance from the start.',
      },
      {
        title: 'Commercial Contracts',
        description: 'Drafting and negotiating agreements with financial institution partners, payment processors, and technology providers.',
      },
      {
        title: 'Securities Law',
        description: 'Registration analysis, exemption strategy, and securities compliance for investment platforms and token offerings.',
      },
      {
        title: 'Regulatory Strategy',
        description: 'Advising on market entry sequencing, regulatory risk, and proactive positioning with Canadian regulators.',
      },
    ]}
  />

  <!-- Testimonials -->
  <Testimonials
    title="What clients say"
    testimonials={[
      {
        testimonial: '[Placeholder — add client testimonial here]',
        name: '[Client Name]',
        job: '[Title, Company]',
      },
      {
        testimonial: '[Placeholder — add client testimonial here]',
        name: '[Client Name]',
        job: '[Title, Company]',
      },
      {
        testimonial: '[Placeholder — add client testimonial here]',
        name: '[Client Name]',
        job: '[Title, Company]',
      },
    ]}
  />

  <!-- Latest insights -->
  <BlogLatestPosts
    id="insights"
    title="Regulatory intelligence"
    information="Practical analysis on Canadian fintech law — MSB registration, FINTRAC compliance, payment structuring, and the regulatory frameworks shaping fintech in Canada."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>

  <!-- CTA -->
  <CallToAction
    title="Request a consultation"
    subtitle="Levine Legal advises fintech founders and operators on Canadian regulatory strategy, corporate structure, and commercial matters."
    actions={[
      {
        variant: 'primary',
        text: 'Get in touch',
        href: getPermalink('/contact'),
      },
    ]}
  />

</PageLayout>
