---
import AuthorityBody from '~/components/sections/authority/AuthorityBody.astro';
import AuthorityCTA from '~/components/sections/authority/AuthorityCTA.astro';
import AuthorityHero from '~/components/sections/authority/AuthorityHero.astro';
import AuthorityInsightLinks from '~/components/sections/authority/AuthorityInsightLinks.astro';
import AuthorityLinkGrid from '~/components/sections/authority/AuthorityLinkGrid.astro';
import AuthorityRelatedTopics from '~/components/sections/authority/AuthorityRelatedTopics.astro';
import { getAuthorityPage } from '~/data/authorityPages';
import Layout from '~/layouts/PageLayout.astro';

const page = getAuthorityPage('fintrac-compliance');
const metadata = { title: page.title, description: page.description };
---

<Layout metadata={metadata}>
  <AuthorityHero page={page} />
  <AuthorityBody paragraphs={page.body} />
  <AuthorityLinkGrid eyebrow="Authority cluster" title="FINTRAC/MSB topics" links={page.primaryLinks || []} />
  <AuthorityRelatedTopics links={page.relatedTopics} />
  <AuthorityInsightLinks links={page.insightLinks} />
  <AuthorityCTA title={page.ctaTitle} text={page.ctaText} />
</Layout>
