---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Fintech Lawyer — Legal information for fintech innovators',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Leading Resources on Fintech Law"
    actions={[
      {
        variant: 'primary',
        text: 'Check Portal',
        href: '/login',
        icon: 'tabler:arrow-right',
      },
      { text: 'View resources', href: '/blog' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Fintech Lawyer hero image' }}
  >
    <Fragment slot="title">
      Legal Systems for Fintech Innovators and Operators
    </Fragment>

    <Fragment slot="subtitle">
      Practical corporate, contract, and regulatory information and counsel for companies operating where legal matters.
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="Areas of focus"
    title="Legal infrastructure for financial technology companies"
    subtitle="Work structured around corporate, contractual, and regulatory alignment"
    items={[
      {
        title: 'Corporate & Governance Structures',
        description: 'Corporate records, ownership, and decision-making frameworks aligned with how the business operates',
        icon: 'tabler:building-bank',
      },
      {
        title: 'Commercial Agreements',
        description: 'Customer, vendor, and platform agreements structured to support scale, financing, and risk allocation',
        icon: 'tabler:file-text',
      },
      {
        title: 'Regulatory Positioning',
        description: 'Interpretation of regulatory obligations across payment flows, licensing, and compliance design',
        icon: 'tabler:scale',
      },
      {
        title: 'Transaction Readiness',
        description: 'Legal infrastructure prepared for financing, diligence, and ownership changes',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Ongoing Counsel',
        description: 'Fractional legal support providing consistent, practical input as the business evolves',
        icon: 'tabler:messages',
      },
      {
        title: 'Preventative Legal Approach',
        description: 'Issues identified and addressed before they become transaction delays or disputes',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <Content
    id="resources"
    isReversed
    tagline="Resources"
    title="How legal infrastructure is developed"
    items={[
      {
        title: 'Initial review',
        description: 'Review of corporate records, agreements, and regulatory positioning',
      },
      {
        title: 'Issue identification',
        description: 'Identification of gaps, risks, and structural misalignment',
      },
      {
        title: 'Implementation',
        description: 'Updates to agreements, governance, and legal structure',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Colorful Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Structured, practical, and aligned with operational reality
      </h3>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    items={[
      {
        title: 'Alignment with operations',
        description: 'Structures reflect actual revenue flows, counterparties, and regulatory exposure',
      },
      {
        title: 'Ongoing alignment',
        description: 'Legal frameworks evolve with financing, hiring, and operational changes',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Blueprint Image',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Steps
    id="how-it-works"
    title="Engagement structure"
    items={[
      {
        title: 'Initial review',
        description: 'Corporate records review, agreement sampling, and regulatory mapping',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Issue identification',
        description: 'Identification of structural gaps, contract risk, and governance misalignment',
        icon: 'tabler:alert-circle',
      },
      {
        title: 'Implementation',
        description: 'Targeted updates to agreements, governance, and legal structure',
        icon: 'tabler:tools',
      },
      {
        title: 'Ongoing support available where required',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  />

  <BlogLatestPosts
    id="topics"
    title="Legal Topics"
    information="Practical writing on corporate and fintech law"
    linkUrl="/blog"
  />

  <FAQs
    title="Common questions"
    subtitle="Key considerations for regulated financial technology businesses"
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How are legal frameworks aligned?',
        description: 'Legal frameworks are aligned with how the business actually operates',
      },
      {
        title: 'What do I need to start?',
        description: 'Corporate records, key agreements, and operational overview',
      },
      {
        title: 'How does the process work?',
        description: 'Structured review → issue identification → implementation',
      },
      {
        title: 'What is usually identified?',
        description: 'Governance gaps, contract inconsistencies, regulatory exposure',
      },
      {
        title: 'When is this relevant?',
        description: 'Prior to financing, expansion, or increased complexity',
      },
      {
        title: 'What is the outcome?',
        description: 'Clear, aligned legal infrastructure supporting operations',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Check Portal',
        href: '/login',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Quality Legal Information for Fintech
    </Fragment>
    <Fragment slot="subtitle">
      Fintech resources, guided next steps, and engagement information.
    </Fragment>
  </CallToAction>
</Layout>
