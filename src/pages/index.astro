---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Fintech Lawyer — Legal information for fintech innovators',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement" />
  <Fragment slot="header">
    <nav id="home-header" class="fixed w-full z-30 top-0 text-white bg-brand-gradient shadow">
      <div class="w-full container mx-auto flex flex-wrap items-center justify-between mt-0 py-2">
        <div class="pl-4 flex items-center">
          <a class="text-white no-underline hover:no-underline font-bold text-2xl lg:text-4xl" href="/tailwindtoolbox-landing-page">
            <svg class="h-8 fill-current inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512.005 512.005">
              <rect fill="#FFFFFF" x="16.539" y="425.626" width="479.767" height="50.502" transform="matrix(1,0,0,1,0,0)" />
              <path
                class="plane-take-off"
                d=" M 510.7 189.151 C 505.271 168.95 484.565 156.956 464.365 162.385 L 330.156 198.367 L 155.924 35.878 L 107.19 49.008 L 211.729 230.183 L 86.232 263.767 L 36.614 224.754 L 0 234.603 L 45.957 314.27 L 65.274 347.727 L 105.802 336.869 L 240.011 300.886 L 349.726 271.469 L 483.935 235.486 C 504.134 230.057 516.129 209.352 510.7 189.151 Z "
              />
            </svg>
            Fintech Lawyer
          </a>
        </div>
        <div class="block lg:hidden pr-4">
          <button
            id="home-nav-toggle"
            class="flex items-center p-1 text-white hover:text-[#DDEAF6] focus:outline-none focus:shadow-outline transform transition hover:scale-105 duration-300 ease-in-out"
            type="button"
            aria-label="Toggle navigation"
          >
            <svg class="fill-current h-6 w-6" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <title>Menu</title>
              <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z" />
            </svg>
          </button>
        </div>
        <div
          class="w-full flex-grow lg:flex lg:items-center lg:w-auto hidden mt-2 lg:mt-0 bg-transparent text-white p-4 lg:p-0 z-20"
          id="home-nav-content"
        >
          <ul class="list-reset lg:flex justify-end flex-1 items-center">
            <li class="mr-3">
              <a class="inline-block py-2 px-4 text-white font-bold no-underline hover:text-[#DDEAF6]" href="#resources">Resources</a>
            </li>
            <li class="mr-3">
              <a class="inline-block text-white no-underline hover:text-[#DDEAF6] py-2 px-4" href="#topics">Topics</a>
            </li>
            <li class="mr-3">
              <a class="inline-block text-white no-underline hover:text-[#DDEAF6] py-2 px-4" href="#how-it-works">How It Works</a>
            </li>
          </ul>
          <a
            href="/login"
            class="mx-auto lg:mx-0 hover:underline bg-white text-[#2E2E2E] font-bold rounded-full mt-4 lg:mt-0 py-4 px-8 shadow opacity-90 focus:outline-none focus:shadow-outline transform transition hover:scale-105 duration-300 ease-in-out"
          >
            Portal
          </a>
        </div>
      </div>
      <hr class="border-b border-[#D1D5DB] opacity-25 my-0 py-0" />
    </nav>
  </Fragment>
  <Fragment slot="footer">
    <footer class="bg-white">
      <div class="container mx-auto px-8">
        <div class="w-full flex flex-col md:flex-row md:items-start md:justify-between py-6">
          <div class="flex-1 mb-6 text-[#2E2E2E]">
            <a class="text-[#1D4771] no-underline hover:no-underline font-bold text-2xl lg:text-4xl" href="/">
              <svg class="h-8 fill-current inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512.005 512.005">
                <rect fill="#1D4771" x="16.539" y="425.626" width="479.767" height="50.502" transform="matrix(1,0,0,1,0,0)" />
                <path
                  class="plane-take-off"
                  d=" M 510.7 189.151 C 505.271 168.95 484.565 156.956 464.365 162.385 L 330.156 198.367 L 155.924 35.878 L 107.19 49.008 L 211.729 230.183 L 86.232 263.767 L 36.614 224.754 L 0 234.603 L 45.957 314.27 L 65.274 347.727 L 105.802 336.869 L 240.011 300.886 L 349.726 271.469 L 483.935 235.486 C 504.134 230.057 516.129 209.352 510.7 189.151 Z "
                />
              </svg>
              Fintech Lawyer
            </a>
          </div>
          <div class="flex flex-col md:flex-row md:justify-end gap-x-12 gap-y-6">
            <div class="md:w-28">
              <p class="uppercase text-[#78716C] md:mb-6">Links</p>
              <ul class="list-reset mb-6">
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/blog" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">FAQ</a>
                </li>
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/blog" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">Help</a>
                </li>
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/login" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">Support</a>
                </li>
              </ul>
            </div>
            <div class="md:w-28">
              <p class="uppercase text-[#78716C] md:mb-6">Legal</p>
              <ul class="list-reset mb-6">
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/terms" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">Terms</a>
                </li>
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/terms" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">Privacy</a>
                </li>
              </ul>
            </div>
            <div class="md:w-28">
              <p class="uppercase text-[#78716C] md:mb-6">Social</p>
              <ul class="list-reset mb-6">
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/blog" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">Facebook</a>
                </li>
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/blog" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">LinkedIn</a>
                </li>
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/blog" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">Twitter</a>
                </li>
              </ul>
            </div>
            <div class="md:w-32">
              <p class="uppercase text-[#78716C] md:mb-6">Company</p>
              <ul class="list-reset mb-6">
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/blog" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">Official Blog</a>
                </li>
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/blog" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">About Us</a>
                </li>
                <li class="mt-2 inline-block mr-2 md:block md:mr-0">
                  <a href="/login" class="no-underline hover:underline text-[#2E2E2E] hover:text-[#0365B2]">Contact</a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </Fragment>
  <script is:inline>
    const homeNavMenuDiv = document.getElementById('home-nav-content');
    const homeNavMenu = document.getElementById('home-nav-toggle');

    if (homeNavMenuDiv && homeNavMenu) {
      document.addEventListener('click', function (event) {
        const target = event.target;
        if (!(target instanceof Node)) return;

        if (homeNavMenu.contains(target)) {
          homeNavMenuDiv.classList.toggle('hidden');
          return;
        }

        if (!homeNavMenuDiv.contains(target)) {
          homeNavMenuDiv.classList.add('hidden');
        }
      });
    }
  </script>
  <div class="h-20"></div>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Leading Resources on Fintech Law"
    actions={[
      {
        variant: 'primary',
        text: 'Check Portal',
        href: '/login',
        icon: 'tabler:arrow-right',
      },
      { text: 'View resources', href: '/blog' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Fintech Lawyer hero image' }}
  >
    <Fragment slot="title">
      Legal Systems for Fintech Innovators and Operators
    </Fragment>

    <Fragment slot="subtitle">
      Practical corporate, contract, and regulatory information and counsel for companies operating where legal matters.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Areas of focus"
    title="Legal infrastructure for financial technology companies"
    subtitle="Work structured around corporate, contractual, and regulatory alignment"
    items={[
      {
        title: 'Corporate & Governance Structures',
        description:
          'Corporate records, ownership, and decision-making frameworks aligned with how the business operates',
        icon: 'tabler:building-bank',
      },
      {
        title: 'Commercial Agreements',
        description:
          'Customer, vendor, and platform agreements structured to support scale, financing, and risk allocation',
        icon: 'tabler:file-text',
      },
      {
        title: 'Regulatory Positioning',
        description:
          'Interpretation of regulatory obligations across payment flows, licensing, and compliance design',
        icon: 'tabler:scale',
      },
      {
        title: 'Transaction Readiness',
        description:
          'Legal infrastructure prepared for financing, diligence, and ownership changes',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Ongoing Counsel',
        description:
          'Fractional legal support providing consistent, practical input as the business evolves',
        icon: 'tabler:messages',
      },
      {
        title: 'Preventative Legal Approach',
        description:
          'Issues identified and addressed before they become transaction delays or disputes',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    id="resources"
    isReversed
    tagline="Resources"
    title="How legal infrastructure is developed"
    items={[
      {
        title: 'Initial review',
        description: 'Review of corporate records, agreements, and regulatory positioning',
      },
      {
        title: 'Issue identification',
        description: 'Identification of gaps, risks, and structural misalignment',
      },
      {
        title: 'Implementation',
        description: 'Updates to agreements, governance, and legal structure',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Colorful Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Structured, practical, and aligned with operational reality
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Alignment with operations',
        description: 'Structures reflect actual revenue flows, counterparties, and regulatory exposure',
      },
      {
        title: 'Ongoing alignment',
        description: 'Legal frameworks evolve with financing, hiring, and operational changes',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Blueprint Image',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="how-it-works"
    title="Engagement structure"
    items={[
      {
        title: 'Initial review',
        description: 'Corporate records review, agreement sampling, and regulatory mapping',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Issue identification',
        description: 'Identification of structural gaps, contract risk, and governance misalignment',
        icon: 'tabler:alert-circle',
      },
      {
        title: 'Implementation',
        description: 'Targeted updates to agreements, governance, and legal structure',
        icon: 'tabler:tools',
      },
      {
        title: 'Ongoing support available where required',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  />

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    id="topics"
    title="Legal Topics"
    information="Practical writing on corporate and fintech law"
    linkUrl="/blog"
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Common questions"
    subtitle="Key considerations for regulated financial technology businesses"
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How are legal frameworks aligned?',
        description:
          "Legal frameworks are aligned with how the business actually operates",
      },
      {
        title: 'What do I need to start?',
        description:
          'Corporate records, key agreements, and operational overview',
      },
      {
        title: 'How does the process work?',
        description:
          "Structured review → issue identification → implementation",
      },
      {
        title: 'What is usually identified?',
        description:
          "Governance gaps, contract inconsistencies, regulatory exposure",
      },
      {
        title: 'When is this relevant?',
        description:
          "Prior to financing, expansion, or increased complexity",
      },
      {
        title: 'What is the outcome?',
        description:
          "Clear, aligned legal infrastructure supporting operations",
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Check Portal',
        href: '/login',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Quality Legal Information for Fintech
    </Fragment>

    <Fragment slot="subtitle">
      Fintech resources, guided next steps, and engagement information.
    </Fragment>
  </CallToAction>
</Layout>
