---
import VerticalPage from '~/components/sections/vertical/VerticalPage.astro';
import { getVerticalPage } from '~/data/verticalPages';
import Layout from '~/layouts/PageLayout.astro';

const page = getVerticalPage('lending');
const metadata = { title: page.title, description: page.description };
---

<Layout metadata={metadata}>
  <VerticalPage page={page} />
</Layout>
