---
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>
      Tailwind Starter Template - Landing Page Template: Tailwind Toolbox
    </title>
    <meta name="description" content="Simple landind page" />
    <meta name="keywords" content="" />
    <meta name="author" content="" />
    <link rel="stylesheet" href="https://unpkg.com/tailwindcss@2.2.19/dist/tailwind.min.css"/>
    <!--Replace with your tailwind.css once created-->
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,700" rel="stylesheet" />
    <!-- Define your gradient here - use online tools to find a gradient matching your branding-->
    <style>
      .gradient {
        background: linear-gradient(90deg, #1D4771 0%, #0365B2 100%);
      }

      .text-\[\#1D4771\] {
        color: #1D4771;
      }

      .text-\[\#2E2E2E\] {
        color: #2E2E2E;
      }

      .text-\[\#57534E\] {
        color: #57534E;
      }

      .text-\[\#78716C\] {
        color: #78716C;
      }

      .hover\:text-\[\#0365B2\]:hover {
        color: #0365B2;
      }

      .hover\:text-\[\#2E2E2E\]:hover {
        color: #2E2E2E;
      }

      .bg-\[\#FAFAF9\] {
        background-color: #FAFAF9;
      }

      .bg-\[\#1D4771\] {
        background-color: #1D4771;
      }

      .border-\[\#D1D5DB\] {
        border-color: #D1D5DB;
      }

      .hidden {
        display: none;
      }
    </style>
  </head>
  <body class="leading-normal tracking-normal text-white gradient" style="font-family: 'Source Sans Pro', sans-serif;">
    <main class="bg-[#FAFAF9] text-[#2E2E2E]">
      <section class="container mx-auto px-4 py-20">
        <div class="max-w-md mx-auto bg-white border border-[#D1D5DB] rounded-lg shadow p-8">
          <p class="uppercase tracking-loose text-[#57534E] text-sm mb-3">PORTAL ACCESS</p>
          <h1 class="text-4xl font-bold leading-tight mb-4">Portal login</h1>
          <p class="text-[#57534E] mb-8">Access the Fintech Lawyer portal for fintech resources, guided next steps, and engagement information.</p>
          <div id="portal-auth-notice" class="hidden border border-[#D1D5DB] rounded bg-[#FAFAF9] text-[#57534E] p-4 mb-5 text-sm"></div>
          <form id="portal-login-form" class="space-y-5">
            <div>
              <label class="block text-sm font-bold mb-2" for="email">Email</label>
              <input id="email" name="email" type="email" autocomplete="email" required class="w-full border border-[#D1D5DB] rounded px-4 py-3 text-[#2E2E2E] focus:outline-none focus:shadow-outline" />
            </div>
            <div>
              <label class="block text-sm font-bold mb-2" for="password">Password</label>
              <input id="password" name="password" type="password" autocomplete="current-password" required class="w-full border border-[#D1D5DB] rounded px-4 py-3 text-[#2E2E2E] focus:outline-none focus:shadow-outline" />
            </div>
            <button id="portal-sign-in" type="submit" class="w-full bg-[#1D4771] text-white font-bold rounded-full py-3 px-6 shadow focus:outline-none focus:shadow-outline transform transition hover:scale-105 duration-300 ease-in-out">Sign in</button>
            <button id="portal-create-account" type="button" class="w-full bg-white border border-[#D1D5DB] text-[#2E2E2E] font-bold rounded-full py-3 px-6 focus:outline-none focus:shadow-outline">Create account</button>
            <button id="portal-password-reset" type="button" class="w-full text-[#1D4771] font-bold underline">Email password reset link</button>
          </form>
          <p class="text-[#57534E] text-sm mt-6">Having trouble accessing the portal? Contact Fintech Lawyer.</p>
        </div>
      </section>
    </main>
    <footer class="bg-white border-t border-[#D1D5DB] text-[#57534E]">
      <div class="container mx-auto px-8 py-6 flex flex-col md:flex-row md:items-center md:justify-between">
        <a class="text-[#1D4771] no-underline hover:no-underline font-bold text-2xl" href="/tailwindtoolbox-landing-page">Fintech Lawyer</a>
        <p class="mt-3 md:mt-0 text-sm">Fintech Lawyer portal experience</p>
      </div>
    </footer>
    <script define:vars={{ supabaseUrl, supabaseAnonKey }}>
      const authNotice = document.getElementById('portal-auth-notice');
      const loginForm = document.getElementById('portal-login-form');
      const createAccountButton = document.getElementById('portal-create-account');
      const passwordResetButton = document.getElementById('portal-password-reset');
      const sessionKey = 'fintech-lawyer-session';

      function showNotice(message, isError = false) {
        if (!authNotice) return;
        authNotice.textContent = message;
        authNotice.classList.remove('hidden');
        authNotice.style.borderColor = isError ? '#b91c1c' : '#D1D5DB';
      }

      function hasSupabaseConfig() {
        return Boolean(supabaseUrl && supabaseAnonKey);
      }

      async function authRequest(path, body) {
        if (!hasSupabaseConfig()) {
          throw new Error('Portal authentication is not configured yet. Add PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY.');
        }

        const response = await fetch(`${supabaseUrl}${path}`, {
          method: 'POST',
          headers: {
            apikey: supabaseAnonKey,
            Authorization: `Bearer ${supabaseAnonKey}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(body),
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(data.error_description || data.msg || data.message || 'Authentication failed.');
        }
        return data;
      }

      function saveSession(data) {
        const expiresAt = Math.floor(Date.now() / 1000) + Number(data.expires_in || 3600);
        window.localStorage.setItem(
          sessionKey,
          JSON.stringify({
            access_token: data.access_token,
            refresh_token: data.refresh_token,
            expires_at: expiresAt,
            user: data.user,
          })
        );
      }

      async function signIn(email, password) {
        const data = await authRequest('/auth/v1/token?grant_type=password', { email, password });
        saveSession(data);
        window.location.href = '/portal';
      }

      async function signUp(email, password) {
        const data = await authRequest('/auth/v1/signup', { email, password });
        if (data.access_token) {
          saveSession(data);
          window.location.href = '/portal';
          return;
        }
        showNotice('Account created. Check your email if confirmation is required before signing in.');
      }

      loginForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const form = new FormData(loginForm);
        try {
          showNotice('Signing in...');
          await signIn(String(form.get('email') || ''), String(form.get('password') || ''));
        } catch (error) {
          showNotice(error.message, true);
        }
      });

      createAccountButton?.addEventListener('click', async () => {
        const form = new FormData(loginForm);
        try {
          showNotice('Creating account...');
          await signUp(String(form.get('email') || ''), String(form.get('password') || ''));
        } catch (error) {
          showNotice(error.message, true);
        }
      });

      passwordResetButton?.addEventListener('click', async () => {
        const form = new FormData(loginForm);
        const email = String(form.get('email') || '');
        try {
          if (!email) throw new Error('Enter your email first.');
          await authRequest('/auth/v1/recover', { email });
          showNotice('Password reset email requested.');
        } catch (error) {
          showNotice(error.message, true);
        }
      });

      if (!hasSupabaseConfig()) {
        showNotice('Portal authentication needs PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY before sign in will work.', true);
      }
    </script>
  </body>
</html>
