<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Fintech Lawyer Portal</title>
    <meta
      name="description"
      content="A post-login education portal for fintech legal readiness, resources, and next steps."
    />
    <link rel="shortcut icon" href="/icons/favicon.png" type="image/png" />
    <link rel="icon" type="image/png" href="/icons/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/favicon.png" />
    <link rel="stylesheet" href="https://unpkg.com/tailwindcss@2.2.19/dist/tailwind.min.css" />
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,700" rel="stylesheet" />
    <style>
      .text-\[\#1D4771\] {
        color: #1D4771;
      }

      .text-\[\#0365B2\] {
        color: #0365B2;
      }

      .text-\[\#2E2E2E\] {
        color: #2E2E2E;
      }

      .text-\[\#57534E\] {
        color: #57534E;
      }

      .text-\[\#78716C\] {
        color: #78716C;
      }

      .bg-\[\#FAFAF9\] {
        background-color: #FAFAF9;
      }

      .bg-\[\#1D4771\] {
        background-color: #1D4771;
      }

      .bg-\[\#DDEAF6\] {
        background-color: #DDEAF6;
      }

      .border-\[\#D1D5DB\] {
        border-color: #D1D5DB;
      }

      .border-\[\#1D4771\] {
        border-color: #1D4771;
      }

      .portal-locked .portal-shell {
        display: none;
      }

      .hidden {
        display: none;
      }
    </style>
  </head>
  <body class="portal-locked bg-[#FAFAF9] text-[#2E2E2E]" style="font-family: 'Source Sans Pro', sans-serif;">
    <div id="portal-auth-gate" class="min-h-screen flex items-center justify-center px-6">
      <div class="max-w-lg bg-white border border-[#D1D5DB] rounded-lg p-6 shadow">
        <p class="uppercase tracking-loose text-[#78716C] text-xs mb-2">Portal access</p>
        <h1 class="text-3xl font-bold mb-3">Checking portal session</h1>
        <p id="portal-auth-gate-message" class="text-[#57534E] mb-5">
          Confirming your Fintech Lawyer portal session.
        </p>
        <a class="inline-block bg-[#1D4771] text-white font-bold rounded-full py-3 px-6 shadow no-underline hover:underline" href="/login">
          Go to login
        </a>
      </div>
    </div>

    <div class="portal-shell min-h-screen lg:flex">
      <aside class="bg-white border-r border-[#D1D5DB] lg:w-72">
        <div class="border-b border-[#D1D5DB] px-6 py-5">
          <a class="text-[#1D4771] no-underline hover:no-underline font-bold text-2xl" href="/tailwindtoolbox-landing-page">
            Fintech Lawyer
          </a>
          <p class="text-[#78716C] text-sm mt-1">Knowledge Portal</p>
        </div>

        <nav class="px-4 py-5">
          <p class="uppercase tracking-loose text-[#78716C] text-xs px-2 mb-3">Portal</p>
          <a class="block rounded border border-[#1D4771] bg-[#DDEAF6] text-[#1D4771] font-bold no-underline px-4 py-3 mb-2" href="#">
            Overview
          </a>
          <a class="block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3 mb-2" href="#discovery-flow">
            Discovery
          </a>
          <a class="block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3 mb-2" href="#topic-library">
            Topics
          </a>
          <a class="block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3 mb-2" href="#resource-library">
            Field Resources
          </a>
          <a class="block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3 mb-2" href="#saved-items">
            Saved
          </a>
          <a class="block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3 mb-2" href="#request-help">
            Requests
          </a>
          <a class="admin-only hidden block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3 mb-2" href="#admin-view">
            Admin
          </a>
          <a class="block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3 mb-2" href="#portal-map">
            Infrastructure
          </a>
          <a class="block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3 mb-2" href="#content-roadmap">
            Roadmap
          </a>
          <a class="block rounded text-[#57534E] hover:text-[#0365B2] no-underline px-4 py-3" href="#portal-consultation">
            Connect
          </a>
        </nav>
      </aside>

      <div class="flex-1">
        <header class="bg-white border-b border-[#D1D5DB] px-6 py-4">
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="uppercase tracking-loose text-[#78716C] text-xs">Legal Infrastructure Platform</p>
              <h1 class="text-3xl font-bold leading-tight">Legal Readiness System</h1>
              <p class="text-[#57534E] mt-2 max-w-3xl">
                Identify structural, regulatory, and operational gaps in your model.
              </p>
            </div>
            <a class="inline-block bg-[#1D4771] text-white font-bold rounded-full py-3 px-6 shadow no-underline hover:underline" href="#request-help">
              Speak with counsel
            </a>
            <div class="flex flex-col gap-2 md:items-end">
              <p id="portal-user-label" class="text-[#57534E] text-sm">Signed in</p>
              <button id="portal-logout" class="border border-[#D1D5DB] rounded-full px-4 py-2 text-[#2E2E2E] bg-white hover:underline" type="button">
                Sign out
              </button>
            </div>
          </div>
        </header>

        <main class="px-6 py-8">
          <section class="mb-6">
            <article class="bg-white border border-[#D1D5DB] rounded-lg shadow p-6">
              <h2 class="text-2xl font-bold mb-3">Continue assessment</h2>
              <p class="text-[#57534E] mb-5 max-w-3xl">
                Map your product, activity, and stage to surface relevant legal signals.
              </p>
              <a class="inline-block bg-[#1D4771] text-white font-bold rounded-full py-3 px-6 shadow no-underline hover:underline" href="#discovery-flow">
                Continue assessment
              </a>
              <div class="mt-5">
