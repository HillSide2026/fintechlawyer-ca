                <li class="mb-2"><a class="text-[#57534E] hover:text-[#0365B2] no-underline hover:underline" href="/insights/fintrac-penalties-case-study">FINTRAC enforcement</a></li>
                <li><a class="text-[#57534E] hover:text-[#0365B2] no-underline hover:underline" href="/insights/stripe-msb-risk-canada">MSB risk</a></li>
              </ul>
            </div>

            <div>
              <p class="font-bold mb-3">Site</p>
              <ul class="list-none p-0 m-0 text-[#57534E]">
                <li class="mb-2"><a class="text-[#57534E] hover:text-[#0365B2] no-underline hover:underline" href="/contact">Contact</a></li>
                <li class="mb-2"><a class="text-[#57534E] hover:text-[#0365B2] no-underline hover:underline" href="/terms">Terms</a></li>
                <li><a class="text-[#57534E] hover:text-[#0365B2] no-underline hover:underline" href="/archive/privacy">Privacy Policy</a></li>
              </ul>
            </div>
          </div>
        </footer>
      </div>
    </div>
    <script define:vars={{ supabaseUrl, supabaseAnonKey, portalNotificationEndpoint }}>
      const topicNames = {
        'payments-msb': 'Payments and MSB registration',
        'fintrac-compliance': 'FINTRAC compliance',
        'lending-credit': 'Lending and credit products',
        'investment-securities': 'Investment and securities issues',
        'insurance-distribution': 'Insurance distribution',
        'embedded-finance': 'Embedded finance',
        'crypto-web3': 'Crypto/Web3',
        'partnership-agreements': 'Partnership agreements',
        'corporate-fundraising': 'Corporate structure and fundraising',
      };

      const topicArtifacts = {
        'payments-msb': ['Payment flow map', 'Partner and processor agreements', 'Customer terms'],
        'fintrac-compliance': ['Compliance policies', 'Risk assessment', 'Training records'],
        'lending-credit': ['Credit product summary', 'Borrower disclosures', 'Servicing workflow'],
        'investment-securities': ['Product description', 'Marketing materials', 'Referral agreements'],
        'insurance-distribution': ['Customer journey', 'Carrier or broker agreements', 'Compensation terms'],
        'embedded-finance': ['Partner role map', 'Customer disclosures', 'Operational responsibility matrix'],
        'crypto-web3': ['Token or product description', 'Wallet and custody model', 'Terms of use'],
        'partnership-agreements': ['Draft partner agreement', 'Service levels', 'Data sharing terms'],
        'corporate-fundraising': ['Corporate records', 'Cap table', 'Board and shareholder approvals'],
      };

      const issueMapNotes = {
        'payments-msb': 'Payment model and MSB exposure',
        'fintrac-compliance': 'AML program and operating evidence',
        'lending-credit': 'Credit role allocation and borrower disclosures',
        'investment-securities': 'Securities, referral, custody, and marketing exposure',
        'insurance-distribution': 'Insurance distribution, licensing, and compensation exposure',
        'embedded-finance': 'Regulated partner, disclosure, and platform role exposure',
        'crypto-web3': 'Token, custody, trading, AML, and securities exposure',
        'partnership-agreements': 'Partner responsibility, liability, and continuity exposure',
        'corporate-fundraising': 'Corporate records, approvals, ownership, and diligence exposure',
      };

      const options = Array.from(document.querySelectorAll('[data-discovery-option]'));
      const topicList = document.getElementById('recommended-topics');
      const riskList = document.getElementById('risk-flags');
      const nextList = document.getElementById('next-steps');
      const issueMap = document.getElementById('issue-map');
      const artifactList = document.getElementById('artifact-list');
      const readinessNote = document.getElementById('readiness-note');
      const summary = document.getElementById('discovery-summary');
      const resetButton = document.getElementById('reset-discovery');
      const resourceCards = Array.from(document.querySelectorAll('[data-resource-card]'));
      const resourceFrameworkFilter = document.getElementById('resource-framework-filter');
      const resourceStageFilter = document.getElementById('resource-stage-filter');
      const resourceTypeFilter = document.getElementById('resource-type-filter');
      const resourceEmpty = document.getElementById('resource-empty');
      const saveButtons = Array.from(document.querySelectorAll('[data-save-resource]'));
      const savedItemsList = document.getElementById('saved-items-list');
      const savedCountSummary = document.getElementById('saved-count-summary');
      const savedCountDetail = document.getElementById('saved-count-detail');
      const clearSavedItems = document.getElementById('clear-saved-items');
      const sessionKey = 'fintech-lawyer-session';
      const authGate = document.getElementById('portal-auth-gate');
      const authGateMessage = document.getElementById('portal-auth-gate-message');
      const userLabel = document.getElementById('portal-user-label');
      const logoutButton = document.getElementById('portal-logout');
      const progressLabel = document.getElementById('assessment-progress-label');
      const progressBar = document.getElementById('assessment-progress-bar');
      const requestHelpForm = document.getElementById('request-help-form');
      const requestHelpStatus = document.getElementById('request-help-status');
      const adminRefresh = document.getElementById('admin-refresh');
      const adminRequestsList = document.getElementById('admin-requests-list');
      const adminActivityList = document.getElementById('admin-activity-list');
      let portalSession = null;
      let portalProfile = null;
      let savedItemsCache = [];

      function hasSupabaseConfig() {
        return Boolean(supabaseUrl && supabaseAnonKey);
      }

      function readLocalSession() {
        try {
          return JSON.parse(window.localStorage.getItem(sessionKey) || 'null');
        } catch {
          return null;
        }
      }

      function writeLocalSession(session) {
        window.localStorage.setItem(sessionKey, JSON.stringify(session));
      }

      function clearLocalSession() {
        window.localStorage.removeItem(sessionKey);
      }

      function getUserId() {
        return portalSession?.user?.id;
      }

      function getUserEmail() {
        return portalSession?.user?.email || 'Signed in';
      }

      async function refreshSessionIfNeeded(session) {
        if (!session?.refresh_token) return session;
        const expiresAt = Number(session.expires_at || 0);
        const now = Math.floor(Date.now() / 1000);
        if (expiresAt > now + 60) return session;

        const response = await fetch(`${supabaseUrl}/auth/v1/token?grant_type=refresh_token`, {
          method: 'POST',
          headers: {
            apikey: supabaseAnonKey,
            Authorization: `Bearer ${supabaseAnonKey}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ refresh_token: session.refresh_token }),
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data.message || 'Portal session expired.');
        const nextSession = {
          access_token: data.access_token,
          refresh_token: data.refresh_token || session.refresh_token,
          expires_at: Math.floor(Date.now() / 1000) + Number(data.expires_in || 3600),
          user: data.user || session.user,
        };
        writeLocalSession(nextSession);
        return nextSession;
      }

      async function apiFetch(path, options = {}) {
        if (!hasSupabaseConfig()) {
          throw new Error('Supabase is not configured.');
        }
        if (!portalSession?.access_token) {
          throw new Error('Portal session is missing.');
        }
        const response = await fetch(`${supabaseUrl}/rest/v1/${path}`, {
          ...options,
          headers: {
            apikey: supabaseAnonKey,
            Authorization: `Bearer ${portalSession.access_token}`,
            'Content-Type': 'application/json',
            Prefer: 'return=representation',
            ...(options.headers || {}),
          },
        });
        const text = await response.text();
        const data = text ? JSON.parse(text) : null;
        if (!response.ok) {
          throw new Error(data?.message || data?.hint || 'Database request failed.');
        }
        return data;
      }

      async function recordActivity(action, metadata = {}) {
        if (!getUserId()) return;
        try {
          await apiFetch('activity_log', {
            method: 'POST',
            body: JSON.stringify({
              user_id: getUserId(),
              action,
              metadata,
            }),
          });
        } catch {
          // Activity logging should never block the user flow.
        }
      }

      async function loadProfile() {
        const userId = getUserId();
        const email = getUserEmail();
        const profiles = await apiFetch(`profiles?user_id=eq.${encodeURIComponent(userId)}&select=*`);
        if (profiles?.[0]) return profiles[0];
        const inserted = await apiFetch('profiles?on_conflict=user_id', {
          method: 'POST',
          headers: { Prefer: 'resolution=merge-duplicates,return=representation' },
          body: JSON.stringify({ user_id: userId, email, role: 'member' }),
        });
        return inserted?.[0] || { user_id: userId, email, role: 'member' };
      }

      async function loadAssessment() {
        const userId = getUserId();
        const rows = await apiFetch(`portal_assessments?user_id=eq.${encodeURIComponent(userId)}&select=*`);
        return rows?.[0] || null;
      }

      async function saveAssessment() {
        const userId = getUserId();
        if (!userId) return;
        const selected = options
          .map((option, index) => ({ option, index }))
          .filter(({ option }) => option.checked)
          .map(({ index }) => index);
        const selectedTopics = unique(
          options.filter((option) => option.checked).flatMap((option) => (option.dataset.topics || '').split('|'))
        );
        const completedSteps = new Set(
          options
            .map((option, index) => ({ option, index }))
            .filter(({ option }) => option.checked)
            .map(({ index }) => Math.floor(index / 3))
        ).size;

        await apiFetch('portal_assessments?on_conflict=user_id', {
          method: 'POST',
          headers: { Prefer: 'resolution=merge-duplicates,return=representation' },
          body: JSON.stringify({
            user_id: userId,
            selected_options: selected,
            recommended_topics: selectedTopics,
            progress_step: Math.max(1, completedSteps),
            updated_at: new Date().toISOString(),
          }),
        });
      }

      function applyAssessment(assessment) {
        if (!assessment?.selected_options) return;
        options.forEach((option, index) => {
          option.checked = assessment.selected_options.includes(index);
        });
        updateDiscoveryResults();
      }

      async function readSavedItems() {
        const userId = getUserId();
        if (!userId || !hasSupabaseConfig()) return savedItemsCache;
        const rows = await apiFetch(
          `saved_resources?user_id=eq.${encodeURIComponent(userId)}&select=id,title,type,framework,stage,href,created_at&order=created_at.desc`
        );
        savedItemsCache = rows || [];
        return savedItemsCache;
      }

      async function writeSavedItems(items) {
        savedItemsCache = items;
      }

      async function renderSavedItems() {
        const savedItems = await readSavedItems();
        if (savedCountSummary) {
          savedCountSummary.textContent = `${savedItems.length} saved`;
        }
        if (savedCountDetail) {
          savedCountDetail.textContent = `${savedItems.length} saved item${savedItems.length === 1 ? '' : 's'}`;
        }
        if (!savedItemsList) return;
        savedItemsList.innerHTML = '';

        if (!savedItems.length) {
          const empty = document.createElement('p');
          empty.className = 'text-[#57534E]';
          empty.textContent = 'Saved resources will appear here.';
          savedItemsList.appendChild(empty);
          return;
        }

        savedItems.forEach((item) => {
          const article = document.createElement('article');
          article.className = 'border border-[#D1D5DB] rounded-lg p-4';

          const title = document.createElement('p');
          title.className = 'font-bold';
          title.textContent = item.title;

          const meta = document.createElement('p');
          meta.className = 'text-[#57534E] text-sm mt-1';
          meta.textContent = `${item.type} | ${item.stage}`;

          const link = document.createElement('a');
          link.className = 'inline-block mt-3 text-[#0365B2] font-bold no-underline hover:underline';
          link.href = item.href;
          link.textContent = 'Open saved item';

          article.appendChild(title);
          article.appendChild(meta);
          article.appendChild(link);
          savedItemsList.appendChild(article);
        });
      }

      async function saveResource(button) {
        const nextItem = {
          user_id: getUserId(),
          title: button.dataset.title,
          type: button.dataset.type,
          framework: button.dataset.framework,
          stage: button.dataset.stage,
          href: button.dataset.href,
        };
        const savedItems = await readSavedItems();
        const exists = savedItems.some((item) => item.title === nextItem.title);
        if (!exists) {
          await apiFetch('saved_resources', {
            method: 'POST',
            body: JSON.stringify(nextItem),
          });
          await writeSavedItems([nextItem, ...savedItems]);
          await recordActivity('saved_resource', { title: nextItem.title });
        }
        await renderSavedItems();
      }

      function renderList(target, items) {
        if (!target) return;
        target.innerHTML = '';
        items.forEach((item) => {
          const li = document.createElement('li');
          li.textContent = item;
          target.appendChild(li);
        });
      }

      function unique(items) {
        return Array.from(new Set(items)).filter(Boolean);
      }

      function updateDiscoveryResults() {
        const selected = options.filter((option) => option.checked);
        const topicIds = unique(selected.flatMap((option) => (option.dataset.topics || '').split('|')));
        const topics = unique(topicIds.map((topic) => topicNames[topic]));
        const risks = unique(selected.map((option) => option.dataset.risk));
        const nextSteps = unique(selected.map((option) => option.dataset.next));
        const artifacts = unique(topicIds.flatMap((topic) => topicArtifacts[topic] || []));
        const issues = unique(topicIds.map((topic) => issueMapNotes[topic]));

        if (!selected.length) {
          renderList(topicList, [
            'Payments and MSB registration',
            'FINTRAC compliance',
            'Partnership agreements',
          ]);
          renderList(riskList, ['Complete the discovery flow to identify risk flags.']);
          renderList(nextList, ['Answer the questions above.', 'Review the matching topic cards.']);
          renderList(issueMap, ['Complete the assessment to build an issue map.']);
          renderList(artifactList, ['Product description', 'Key agreements', 'Current operating flow']);
          if (readinessNote) {
            readinessNote.textContent = 'The system will produce a concise readiness note after selections are made.';
          }
          if (summary) {
            summary.textContent = 'Select options above to generate recommended topics and next steps.';
          }
          return;
        }

        renderList(topicList, topics);
        renderList(riskList, risks);
        renderList(nextList, nextSteps);
        renderList(issueMap, issues);
        renderList(artifactList, artifacts.slice(0, 8));
        if (readinessNote) {
          readinessNote.textContent = `${topics.length} framework${topics.length === 1 ? '' : 's'} identified. Start with the artifacts listed here, then review the matching framework blocks and field resources.`;
        }
        if (summary) {
          summary.textContent = `${selected.length} selection${selected.length === 1 ? '' : 's'} made. Review the recommended topics, risk flags, and next steps below.`;
        }

        const completedSteps = new Set(
          selected.map((selectedOption) => Math.floor(options.indexOf(selectedOption) / 3))
        ).size;
        const progress = Math.max(1, completedSteps);
        if (progressLabel) {
          progressLabel.textContent = `Assessment progress: ${progress} / 3`;
        }
        if (progressBar) {
          progressBar.style.width = `${Math.min(100, Math.round((progress / 3) * 100))}%`;
        }
      }

      function updateResourceFilters() {
        const framework = resourceFrameworkFilter?.value || 'all';
        const stage = resourceStageFilter?.value || 'all';
        const type = resourceTypeFilter?.value || 'all';
        let visibleCount = 0;

        resourceCards.forEach((card) => {
          const frameworkMatch = framework === 'all' || card.dataset.framework === framework;
          const stageMatch = stage === 'all' || card.dataset.stage === stage;
          const typeMatch = type === 'all' || card.dataset.type === type;
          const isVisible = frameworkMatch && stageMatch && typeMatch;
          card.classList.toggle('hidden', !isVisible);
          if (isVisible) visibleCount += 1;
        });

        resourceEmpty?.classList.toggle('hidden', visibleCount !== 0);
      }

      async function submitRequest(event) {
        event.preventDefault();
        if (!requestHelpForm || !getUserId()) return;
        const form = new FormData(requestHelpForm);
        const request = {
          user_id: getUserId(),
          request_type: String(form.get('request_type') || ''),
          timeline: String(form.get('timeline') || ''),
          company: String(form.get('company') || ''),
          framework: String(form.get('framework') || ''),
          summary: String(form.get('summary') || ''),
          documents: String(form.get('documents') || ''),
          status: 'submitted',
        };
        try {
          if (requestHelpStatus) requestHelpStatus.textContent = 'Submitting request...';
          const inserted = await apiFetch('consultation_requests', {
            method: 'POST',
            body: JSON.stringify(request),
          });
          await recordActivity('submitted_request', { request_type: request.request_type, framework: request.framework });
          if (portalNotificationEndpoint) {
            await fetch(portalNotificationEndpoint, {
              method: 'POST',
              headers: {
                Authorization: `Bearer ${portalSession.access_token}`,
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ type: 'consultation_request', request: inserted?.[0] || request }),
            }).catch(() => null);
          }
          requestHelpForm.reset();
          if (requestHelpStatus) requestHelpStatus.textContent = 'Request submitted. It is now saved in the portal.';
          await loadAdminData();
        } catch (error) {
          if (requestHelpStatus) requestHelpStatus.textContent = error.message;
        }
      }

      async function loadAdminData() {
        if (portalProfile?.role !== 'admin') return;
        try {
          const requests = await apiFetch('consultation_requests?select=*&order=created_at.desc&limit=10');
          if (adminRequestsList) {
            adminRequestsList.innerHTML = '';
            if (!requests?.length) {
              adminRequestsList.innerHTML = '<p class="text-[#57534E]">No requests yet.</p>';
            } else {
              requests.forEach((request) => {
                const article = document.createElement('article');
                article.className = 'border border-[#D1D5DB] rounded-lg p-4';
                article.innerHTML = `<p class="font-bold">${request.request_type || 'Request'}</p><p class="text-[#57534E] text-sm">${request.company || 'No company'} | ${request.timeline || 'No timeline'} | ${request.status || 'submitted'}</p><p class="text-[#57534E] mt-2">${request.summary || ''}</p>`;
                adminRequestsList.appendChild(article);
              });
            }
          }

          const activity = await apiFetch('activity_log?select=*&order=created_at.desc&limit=10');
          if (adminActivityList) {
            adminActivityList.innerHTML = '';
            if (!activity?.length) {
              adminActivityList.innerHTML = '<p class="text-[#57534E]">No activity yet.</p>';
            } else {
              activity.forEach((item) => {
                const article = document.createElement('article');
                article.className = 'border border-[#D1D5DB] rounded-lg p-4';
                article.innerHTML = `<p class="font-bold">${item.action}</p><p class="text-[#57534E] text-sm">${new Date(item.created_at).toLocaleString()}</p>`;
                adminActivityList.appendChild(article);
              });
            }
          }
        } catch (error) {
          if (adminRequestsList) adminRequestsList.innerHTML = `<p class="text-[#57534E]">${error.message}</p>`;
        }
      }

      async function initializePortal() {
        try {
          if (!hasSupabaseConfig()) {
            throw new Error('Portal backend is not configured. Add PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY.');
          }
          const localSession = readLocalSession();
          if (!localSession?.access_token) {
            window.location.href = '/login';
            return;
          }
          portalSession = await refreshSessionIfNeeded(localSession);
          portalProfile = await loadProfile();
          if (userLabel) userLabel.textContent = getUserEmail();
          document.body.classList.remove('portal-locked');
          authGate?.classList.add('hidden');

          if (portalProfile?.role === 'admin') {
            document.querySelectorAll('.admin-only').forEach((element) => element.classList.remove('hidden'));
            await loadAdminData();
          }

          const assessment = await loadAssessment();
          applyAssessment(assessment);
          await renderSavedItems();
          await recordActivity('portal_opened', {});
        } catch (error) {
          if (authGateMessage) authGateMessage.textContent = error.message;
        }
      }

      options.forEach((option) =>
        option.addEventListener('change', async () => {
          updateDiscoveryResults();
          try {
            await saveAssessment();
            await recordActivity('updated_assessment', {});
          } catch {
            // Assessment remains usable even when persistence fails.
          }
        })
      );
      resetButton?.addEventListener('click', () => {
        options.forEach((option) => {
          option.checked = false;
        });
        updateDiscoveryResults();
        saveAssessment().catch(() => null);
      });
      resourceFrameworkFilter?.addEventListener('change', updateResourceFilters);
      resourceStageFilter?.addEventListener('change', updateResourceFilters);
      resourceTypeFilter?.addEventListener('change', updateResourceFilters);
      saveButtons.forEach((button) => button.addEventListener('click', () => saveResource(button)));
      clearSavedItems?.addEventListener('click', async () => {
        const userId = getUserId();
        if (userId) {
          await apiFetch(`saved_resources?user_id=eq.${encodeURIComponent(userId)}`, { method: 'DELETE' }).catch(() => null);
        }
        await writeSavedItems([]);
        await renderSavedItems();
      });
      requestHelpForm?.addEventListener('submit', submitRequest);
      adminRefresh?.addEventListener('click', loadAdminData);
      logoutButton?.addEventListener('click', () => {
        clearLocalSession();
        window.location.href = '/login';
      });
      updateResourceFilters();
      initializePortal();
    </script>
  </body>
</html>
